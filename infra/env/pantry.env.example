# Pantry self-hosted environment example for Docker on a Debian LXC.
# Copy this file to .env in your install directory and replace the placeholder values.

PANTRY_VERSION=0.1.0
PANTRY_IMAGE_NAMESPACE=ghcr.io/robro92

ENVIRONMENT=production
DEPLOYMENT_MODE=self_hosted
DEMO_MODE_ENABLED=false
LOG_LEVEL=INFO
AI_FEATURE_ENABLED=true

WEB_BIND_ADDRESS=0.0.0.0
WEB_PORT=3000
API_BIND_ADDRESS=0.0.0.0
API_PORT=8000

POSTGRES_DB=pantry
POSTGRES_USER=pantry
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql+psycopg://pantry:replace-me@postgres:5432/pantry
REDIS_URL=redis://redis:6379/0

WEB_APP_URL=http://your-server-ip:3000
API_BASE_URL=http://your-server-ip:8000
NEXT_PUBLIC_API_BASE_URL=http://your-server-ip:8000
INTERNAL_API_BASE_URL=http://api:8000
PUBLIC_BROWSER_BASE_URL=http://your-server-ip:3000

PANTRY_POSTGRES_DATA_DIR=/srv/pantry/postgres
PANTRY_REDIS_DATA_DIR=/srv/pantry/redis
PANTRY_IMPORTS_DATA_DIR=/srv/pantry/imports
IMPORT_STORAGE_ROOT=/var/lib/pantry/imports
IMPORT_MAX_UPLOAD_BYTES=10485760

SETTINGS_ENCRYPTION_KEY=replace-with-a-long-random-secret
SESSION_SECRET_KEY=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=pantry_session
SESSION_MAX_AGE_SECONDS=604800
SESSION_HTTPS_ONLY=false
SESSION_SAME_SITE=lax

WORKER_POLL_INTERVAL_SECONDS=30

RELEASE_CHECK_REPOSITORY=RoBro92/pantry
RELEASE_CHECK_METADATA_URL=
RELEASE_CHECK_TIMEOUT_SECONDS=5

OLLAMA_BASE_URL=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=

SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_SECURITY=
SMTP_ENABLED=
SMTP_TIMEOUT_SECONDS=5
