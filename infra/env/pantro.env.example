# Pantro self-hosted environment example for Docker on a Debian LXC.

PANTRO_VERSION=0.2.1
PANTRO_IMAGE_NAMESPACE=ghcr.io/robro92

WEB_BIND_ADDRESS=0.0.0.0
WEB_PORT=3000
API_BIND_ADDRESS=0.0.0.0
API_PORT=8000

POSTGRES_DB=pantro
POSTGRES_USER=pantro
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql+psycopg://pantro:replace-me@postgres:5432/pantro
REDIS_URL=redis://redis:6379/0

WEB_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
PUBLIC_BROWSER_BASE_URL=http://localhost:3000
INTERNAL_API_BASE_URL=http://api:8000

PANTRO_POSTGRES_DATA_DIR=/srv/pantro/postgres
PANTRO_REDIS_DATA_DIR=/srv/pantro/redis
PANTRO_IMPORTS_DATA_DIR=/srv/pantro/imports
PANTRO_BACKUPS_DATA_DIR=/srv/pantro/backups
IMPORT_STORAGE_ROOT=/var/lib/pantro/imports
BACKUP_STORAGE_ROOT=/var/lib/pantro/backups
IMPORT_MAX_UPLOAD_BYTES=10485760

SETTINGS_ENCRYPTION_KEY=replace-with-random-secret
SESSION_SECRET_KEY=replace-with-random-secret
SESSION_COOKIE_NAME=pantro_session
SESSION_MAX_AGE_SECONDS=604800
SESSION_HTTPS_ONLY=true
SESSION_SAME_SITE=lax
CSRF_PROTECTION_ENABLED=true
CSRF_TRUSTED_ORIGINS=
INTERNAL_API_PROXY_TOKEN=replace-with-random-secret
RATE_LIMIT_REDIS_ENABLED=true
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
PASSWORD_RESET_RATE_LIMIT_ATTEMPTS=5
PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=3600
SETUP_MUTATION_RATE_LIMIT_ATTEMPTS=30
SETUP_MUTATION_RATE_LIMIT_WINDOW_SECONDS=300

ENVIRONMENT=production
LOG_LEVEL=INFO
DEPLOYMENT_MODE=self_hosted
DEMO_MODE_ENABLED=false
AI_FEATURE_ENABLED=true

OLLAMA_BASE_URL=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_SECURITY=
SMTP_ENABLED=
SMTP_TIMEOUT_SECONDS=5
WORKER_POLL_INTERVAL_SECONDS=30

RELEASE_CHECK_REPOSITORY=RoBro92/pantry
RELEASE_CHECK_METADATA_URL=
RELEASE_CHECK_TIMEOUT_SECONDS=5
