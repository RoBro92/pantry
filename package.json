{
  "name": "pantry",
  "private": true,
  "packageManager": "npm@10",
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10 <11"
  },
  "workspaces": [
    "apps/web",
    "packages/shared-types"
  ],
  "scripts": {
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down",
    "compose:dev:fresh": "./infra/scripts/dev-stack.sh start fresh",
    "compose:dev:demo": "./infra/scripts/dev-stack.sh start demo",
    "compose:dev:down": "./infra/scripts/dev-stack.sh down",
    "compose:dev:logs": "./infra/scripts/dev-stack.sh logs",
    "compose:dev:rebuild": "./infra/scripts/dev-stack.sh rebuild",
    "dev:stack": "./infra/scripts/dev-stack.sh",
    "dev:stack:fresh": "./infra/scripts/dev-stack.sh start fresh",
    "dev:stack:demo": "./infra/scripts/dev-stack.sh start demo",
    "dev:stack:reset:fresh": "./infra/scripts/dev-stack.sh reset fresh",
    "dev:stack:reset:demo": "./infra/scripts/dev-stack.sh reset demo",
    "dev:stack:rebuild": "./infra/scripts/dev-stack.sh rebuild",
    "dev:stack:down": "./infra/scripts/dev-stack.sh down",
    "dev:stack:logs": "./infra/scripts/dev-stack.sh logs",
    "dev:web": "sh -lc 'export NEXT_PUBLIC_APP_VERSION=$(./infra/scripts/read-version.sh); npm run dev --workspace @pantry/web'",
    "build:web": "sh -lc 'export NEXT_PUBLIC_APP_VERSION=$(./infra/scripts/read-version.sh); npm run build --workspace @pantry/web'",
    "typecheck:web": "sh -lc 'export NEXT_PUBLIC_APP_VERSION=$(./infra/scripts/read-version.sh); npm run typecheck --workspace @pantry/web'",
    "test:e2e": "playwright test",
    "version:show": "./infra/scripts/read-version.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
