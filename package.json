{
  "name": "pantry",
  "private": true,
  "packageManager": "npm@10",
  "workspaces": [
    "apps/web",
    "packages/shared-types"
  ],
  "scripts": {
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down",
    "dev:web": "npm run dev --workspace @pantry/web",
    "build:web": "npm run build --workspace @pantry/web",
    "typecheck:web": "npm run typecheck --workspace @pantry/web",
    "version:show": "./infra/scripts/read-version.sh"
  }
}

