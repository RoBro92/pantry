ENVIRONMENT=development
LOG_LEVEL=INFO
WEB_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
API_BASE_URL=http://localhost:8000
AI_FEATURE_ENABLED=true
POSTGRES_DB=pantry
POSTGRES_USER=pantry
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://pantry:change-me@postgres:5432/pantry
REDIS_URL=redis://redis:6379/0
WEB_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
INTERNAL_API_BASE_URL=http://api:8000
SETTINGS_ENCRYPTION_KEY=
SESSION_SECRET_KEY=change-me-for-production
SESSION_COOKIE_NAME=pantry_session
SESSION_MAX_AGE_SECONDS=604800
SESSION_HTTPS_ONLY=false
SESSION_SAME_SITE=lax
OLLAMA_BASE_URL=http://host.docker.internal:11434
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
WORKER_POLL_INTERVAL_SECONDS=30
IMPORT_STORAGE_ROOT=/workspace/.local/imports
IMPORT_MAX_UPLOAD_BYTES=10485760
