ENVIRONMENT=development
DEPLOYMENT_MODE=self_hosted
DEMO_MODE_ENABLED=false
LOG_LEVEL=INFO
WEB_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
API_BASE_URL=http://localhost:8000
AI_FEATURE_ENABLED=true
POSTGRES_DB=pantro
POSTGRES_USER=pantro
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://pantro:change-me@postgres:5432/pantro
REDIS_URL=redis://redis:6379/0
WEB_APP_URL=http://localhost:3000
PUBLIC_BROWSER_BASE_URL=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
INTERNAL_API_BASE_URL=http://api:8000
SETTINGS_ENCRYPTION_KEY=
SESSION_SECRET_KEY=change-me-for-development
SESSION_COOKIE_NAME=pantro_session
SESSION_MAX_AGE_SECONDS=604800
SESSION_HTTPS_ONLY=false
SESSION_SAME_SITE=lax
OLLAMA_BASE_URL=http://host.docker.internal:11434
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_SECURITY=
SMTP_ENABLED=
SMTP_TIMEOUT_SECONDS=5
WORKER_POLL_INTERVAL_SECONDS=30
IMPORT_STORAGE_ROOT=/workspace/.local/imports
IMPORT_MAX_UPLOAD_BYTES=10485760
RELEASE_CHECK_REPOSITORY=
RELEASE_CHECK_METADATA_URL=
RELEASE_CHECK_TIMEOUT_SECONDS=5

# Local-only demo seed bootstrap.
# Leave these blank unless you want ./pantro start --demo or ./pantro reset --demo
# to save AI/SMTP settings into the local demo database automatically.

# Pantro AI demo bootstrap
PANTRO_LOCAL_AI_PROVIDER_TYPE=openai
PANTRO_LOCAL_AI_BASE_URL=https://api.openai.com/v1
PANTRO_LOCAL_AI_DEFAULT_MODEL=gpt-5.4-mini
PANTRO_LOCAL_AI_API_KEY=
PANTRO_LOCAL_AI_ENABLED=true

# Pantro SMTP demo bootstrap
PANTRO_LOCAL_SMTP_HOST=
PANTRO_LOCAL_SMTP_PORT=587
PANTRO_LOCAL_SMTP_USERNAME=
PANTRO_LOCAL_SMTP_PASSWORD=
PANTRO_LOCAL_SMTP_FROM_EMAIL=
PANTRO_LOCAL_SMTP_FROM_NAME=Pantro Local
PANTRO_LOCAL_SMTP_SECURITY=starttls
PANTRO_LOCAL_SMTP_ENABLED=true
PANTRO_LOCAL_SMTP_TEST_RECIPIENT_EMAIL=
PANTRO_LOCAL_SMTP_PASSWORD_RESET_ENABLED=false
